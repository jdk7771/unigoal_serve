import networkx as nx
from networkx.utils import union_subgraph, disjoint_union

def decompose_into_subgraphs(graph):
    subgraphs = []
    while len(graph.nodes) > 0:
        node = graph.nodes[list(graph.nodes)[0]]
        subgraph = nx.subgraph(graph, [node])
        subgraphs.append(subgraph)
        graph.remove_node(node)
    return subgraphs

