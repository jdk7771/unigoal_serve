import networkx as nx

def decompose_graph(graph):
    # Extract nodes and edges
    nodes = graph['nodes']
    edges = graph['edges']

    # Initialize an empty list to store subgraphs
    subgraphs = []

    # Iterate over each node
    for node in nodes:
        # Initialize a flag to track if the node is strongly related to another node
        strongly_related = False

        # Iterate over each subgraph in the list
        for subgraph in subgraphs:
            # Check if the node has an edge with a node in the subgraph
            for subgraph_node in subgraph['nodes']:
                if any(edge['source'] == node['id'] and edge['target'] == subgraph_node['id'] or 
                       edge['target'] == node['id'] and edge['source'] == subgraph_node['id']
                       for edge in edges):
                    strongly_related = True
                    break

            # If the node is strongly related to the subgraph, break the loop
            if strongly_related:
                break

        # If the node is not strongly related to any subgraph, create a new subgraph
        if not strongly_related:
            subgraphs.append({
                'nodes': [node],
                'edges': [{'source': node['id'], 'target': node['id'], 'type': 'unrelated'}]
            })

        # If the node is strongly related to a subgraph, add it to the subgraph
        else:
