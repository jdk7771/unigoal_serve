    graph = {
        'nodes': {
            'person': {'id': 'person', 'attributes': {}},
            'chair': {'id': 'chair', 'attributes': {}},
            'table': {'id': 'table', 'attributes': {}}
        },
        'edges': [
            {'source': 'person', 'target': 'chair', 'type': 'related'},
            {'source': 'chair', 'target': 'table', 'type': 'related'}
        ]
    }

    # Create a graph dictionary for each node with strongly related nodes
    subgraphs = defaultdict(dict)
    for node, node_info in graph['nodes'].items():
        subgraphs[node] = {'nodes': [node_info], 'edges': []}

    # Populate strongly_related_subgraph list in subgraphs dictionary
    for edge in graph['edges']:
        source_subgraph = [subgraph for subgraph, node_info in subgraphs.items() 
                          if node_info['nodes'][0]['id'] == edge['source']][0]
        target_subgraph = [subgraph for subgraph, node_info in subgraphs.items() 
                          if node_info['nodes'][0]['id'] == edge['target']][0]
        source_subgraph['edges'].append({'source': edge['source'], 'target': edge['target'], 'type': edge['type']})
        target_subgraph['edges'].append({'source': edge['target'], 'target': edge['source'], 'type': edge['type']})

    # Rebuild subgraphs dictionary with strongly related subgraphs
    result = {}
    i = 1
    for subgraph_id, subgraph_info in subgraphs.items():
        result[f'subgraph_{i}'] = subgraph_info
        i += 1

    return result


