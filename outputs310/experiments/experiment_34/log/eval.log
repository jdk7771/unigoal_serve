import networkx as nx

def decompose_graph(input_graph):
    g = nx.DiGraph()
    strong_nodes = []
    weak_nodes = []
    g.add_nodes_from(input_graph['nodes'], id=n[0] for n in input_graph['nodes'])
    g.add_edges_from([edge for edge in input_graph['edges'] if edge['type'] == 'strong'])

    for node in input_graph['nodes']:
        if g.has_node(node['id']):
            g.nodes[node['id']]['subgraph'] = 'subgraph_1'
            strong_nodes.append(node)
        else:
            weak_nodes.append(node)

    subgraph_1_nodes = [{'id': n['id']} for n in strong_nodes]
    subgraph_1_edges = [{'source': e['source'], 'target': e['target'], 'type': e['type']} for e in g.edges(data=False)]

    subgraph_1_data = {'subgraph_1': {'nodes': subgraph_1_nodes, 'edges': subgraph_1_edges}}

    for node_weak in weak_nodes:
        new_id = len(g) + 1
        g.add_node(new_id, {'id': node_weak['id'], 'subgraph': f'subgraph_{len(subgraph_1_data)}'})
        g.add_edges_from([(node_weak['id'], new_id, {'type': 'weak'})])

    subgraph_n_data = {f'subgraph_{sub+2}': {'nodes': [], 'edges': []} for sub in range(len(subgraph_1_data))}

    for node, attrs in g.nodes(data=True):
        if 'subgraph' in attrs: del attrs['subgraph']

        if attrs['id'] not in [n['id'] for n in subgraph_1_nodes]:
            sub_id = attrs['id']
            node_data = {'id': sub_id}
            subgraph_n_data[f'subgraph_{g.nodes[node]['subgraph']}']['nodes'].append(node_data)
            for edge in g.edges(node, data=True):
