from collections import defaultdict

def decompose_graph(nodes, edges):
    """
    Decompose a graph into a set of subgraphs where each subgraph contains strongly related nodes.

    Parameters:
    nodes (list): The nodes in the graph.
    edges (list): The edges in the graph.

    Returns:
    dict: A dictionary of subgraphs, where each subgraph has its own 'nodes' and 'edges' list.
    """

    # Create a dictionary to store the subgraphs
    subgraphs = defaultdict(lambda: {'nodes': [], 'edges': []})

    # Initialize the subgraphs with all nodes in a single subgraph
    current_subgraph = 'subgraph_1'

    for node in nodes:
        # Add the node to the current subgraph
        subgraphs[current_subgraph]['nodes'].append({'id': node})

    # Add edges to the current subgraph
    for edge in edges:
        # If the nodes in the edge are already in the current subgraph, add the edge
        if {'source': edge['source'], 'target': edge['target']} in [(edge['source'], edge['target']), (edge['target'], edge['source'])]:
            subgraphs[current_subgraph]['edges'].append(edge)

    return dict(subgraphs)

