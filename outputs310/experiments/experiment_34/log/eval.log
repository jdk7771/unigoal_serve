from collections import defaultdict, deque

def decompose_graph(graph):
    """
    Decomposes the input graph into strongly connected subgraphs.

    Args:
    graph (dict): The input graph represented as a dictionary of nodes. Each key is a node ID, and its value is a list of adjacent node IDs.

    Returns:
    dict: A dictionary of strongly connected subgraphs. Each key is a subgraph ID, and its value is another dictionary containing the subgraph's nodes and edges.
    """

    # Initialize the result dictionary
    subgraphs = defaultdict(dict)

    # Initialize the strongly connected components in visited list
    visited = set()

    # Initialize the stack and low values for strongly connected components
    stack = []
    low_values = {}
    indices = {}

    def strong_connect(node, id):
        """
        Performs a depth-first search on the graph starting from the given node and returns the strongly connected subgraph containing it.

        Args:
        node (str): The node ID to start the depth-first search from.
        id (str): The ID of the strongly connected subgraph.
        """

        # Mark the current node as visited
        visited.add(node)

        # Initialize the stack with the current node and set its index to the current index
        stack.append(node)
        indices[node] = id
        low_values[node] = indices[node]

        # Get the adjacent nodes of the current node
        adj_nodes = graph.get(node, [])

        # Recursively visit all adjacent nodes
        for adj_node in adj_nodes:
            if adj_node not in visited:
                # If the adjacent node is not visited, recursively visit it
                strong_connect(adj_node, id)

                # Update the low value of the current node
                low_values[node] = min(low_values[node], low_values[adj_node])

                # If the current node is a root node (i.e., its index equals its low value), it means we've found a strongly connected component
                if low_values[node] == indices[node]:
                    # Add all nodes in the current strongly connected component to the result dictionary
                    subgraphs[id] = {'nodes': [], 'edges': []}
                    while stack[-1] != adj_node:
                        subgraphs[id]['nodes'].append(stack.pop())
                        subgraphs[id]['edges'].append({
                            'source': stack[-1],
                            'target': indices[stack[-1]],
                            'type': 'STRONG'
                        })

                    # Remove the root node from the stack (i.e., the current node)
                    subgraphs[id]['nodes'].append(stack.pop())
                    subgraphs[id]['edges'].append({
                        'source': node,
                        'target': indices[node],
                        'type': 'STRONG'
                    })
            else:
                # If the adjacent node is visited, update the low value of the current node if necessary
                low_values[node] = min(low_values[node], low_values[adj_node])

    # Start the depth-first search from each unvisited node
    for node in graph:
        if node not in visited:
            strong_connect(node, str(len(subgraphs)))

    return dict(subgraphs)


