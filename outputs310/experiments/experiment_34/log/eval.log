import re

def decompose_graph(input_str):
    nodes = ['chair']
    edges = []

    pattern = re.compile(r"(\w+) -> (\w+) \((\w+)\)")
    matches = [pattern.match(edge) for edge in input_str.split('.')]
    matches = [match for match in matches if match is not None]

    relations = set()
    for match in matches:
        relation = match.group(3)
        relations.add((match.group(1), match.group(2), relation))

    subgraphs = {}

    subgraph_id = 1

    for relation in relations:
        node1, node2, relation_type = relation
        node = (node1, node2)

        subgraph_id_found = False

        for subgraph_id_key in subgraphs:
            if node in subgraphs[subgraph_id_key]['edges']:
                subgraph_id_found = True
                break

        if not subgraph_id_found:
            subgraph_nodes = [node for n in relations if n[0] == node1 or n[1] == node1]
            subgraph_edges = [edge for edge in edges if (edge[1] == node1 or edge[0] == node1) or (edge[1] == node2 or edge[0] == node2)]
            subgraph_edges_with_nodes = [(u, v, 'relation') for u, v in subgraph_edges if u in subgraph_nodes and v in subgraph_nodes]
            subgraphs[f'subgraph_{subgraph_id}'] = {
                'nodes': [{'id': node1} for node in subgraph_nodes],
                'edges': subgraph_edges_with_nodes
            }
            subgraph_id += 1
        else:
            subgraph_id_key = subgraph_id_found
            subgraphs[subgraph_id_key]['edges'].append({
                'source': node1,
                'target': node2,
                'type': relation_type
            })

    return {f'subgraph_{key}': val for key, val in subgraphs.items()}

