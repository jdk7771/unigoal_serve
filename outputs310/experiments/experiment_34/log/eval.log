                        'source': node_data['id'],
                        'target': edge[1],
                        'type': edge[2]['type']
                        })

    subgraphs_data = {**subgraph_1_data, **subgraph_n_data}

    for key, subgraph in subgraphs_data.items():
        if not subgraph['nodes']:
            del subgraphs_data[key]
           

    return subgraphs_data

