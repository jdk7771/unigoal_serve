from collections import defaultdict, deque

class Graph:
    def __init__(self):
        self.graph = defaultdict(list)

    def add_node(self, node_id):
        self.graph[node_id] = []

    def add_edge(self, source, target, relation_type):
        self.graph[source].append({'target': target, 'relation_type': relation_type})

    def get_subgraphs(self):
        subgraphs = []
        visited = set()

        for node_id in self.graph:
            if node_id not in visited:
                subgraph = []
                stack = [(node_id, None)]

                while stack:
                    node_id, prev_node_id = stack.pop()
                    if node_id not in visited:
                        visited.add(node_id)
                        subgraph.append({'id': node_id})
                        stack.extend((target, node_id) for target in self.graph[node_id] if target['target'] not in visited)

                subgraph_edges = []
                for node_id in subgraph:
                    for edge in self.graph[node_id]:
                        if edge['target'] in subgraph:
                            subgraph_edges.append({'source': node_id, 'target': edge['target'], 'type': edge['relation_type']})

                subgraphs.append({'nodes': subgraph, 'edges': subgraph_edges})

        return subgraphs

