def decompose_graph(nodes, edges):
    graph = defaultdict(list)
    subgraphs = defaultdict(list)
    
    # Construct the graph
    for edge in edges:
        type, node = edge
        graph[type].append(node)
    
    # Initialize the subgraphs
    for node in nodes:
        for key, values in graph.items():
            if node['id'] in values:
                subgraphs[key].append(node)
    
