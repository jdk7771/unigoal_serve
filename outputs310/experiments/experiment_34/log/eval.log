from collections import defaultdict

def decompose_graph(n):
    """
    Decompose a graph into a set of subgraphs where each subgraph contains strongly related nodes.

    Args:
    n (dict): A dictionary representing the graph, where each key is a node ID and each value is a list of its strongly related node IDs.

    Returns:
    dict: A dictionary representing the decomposed graph, where each key is a subgraph ID, and each value is a dictionary containing the nodes and edges of that subgraph.
    """

    # Initialize an empty dictionary to store the decomposed graph
    decomposed_graph = defaultdict(dict)

    # Initialize a counter for subgraph IDs
    subgraph_id = 1

    # Loop through each node in the graph
    for node, strongly_related_nodes in n.items():
        # Add the current node to the set of nodes in the current subgraph
        decomposed_graph[f'subgraph_{subgraph_id}']['nodes'].append({'id': node})

        # Loop through each of the current node's strongly related nodes
        for strongly_related_node in strongly_related_nodes:
            # Add the strongly related node to the set of nodes in the current subgraph
            decomposed_graph[f'subgraph_{subgraph_id}']['nodes'].append({'id': strongly_related_node})

    # Create a set to keep track of all visited nodes
    visited = set()

    # Loop through each node in the graph
    for node, strongly_related_nodes in n.items():
        # If the current node has not been visited yet
        if node not in visited:
            # Initialize the current subgraph
            subgraph = {'nodes': [{'id': node}], 'edges': [], 'subgraph_id': 1}

            # Mark the current node as visited
            visited.add(node)

            # Initialize a stack with the current node
            stack = [node]

            # Perform a depth-first search to add all strongly related nodes to the current subgraph
            while stack:
                # Pop the top node from the stack
                current_node = stack.pop()

                # Loop through each of the current node's strongly related nodes
                for strongly_related_node in n[current_node]:
                    # If the strongly related node has not been visited yet
                    if strongly_related_node not in visited:
                        # Mark the strongly related node as visited
                        visited.add(strongly_related_node)

                        # Add the strongly related node to the stack
                        stack.append(strongly_related_node)

                        # Add the strongly related node to the current subgraph
                        subgraph['nodes'].append({'id': strongly_related_node})

                        # Add an edge between the current node and the strongly related node
                        subgraph['edges'].append({
                            'source': current_node,
                            'target': strongly_related_node,
                            'type': 'strong relation'
                        })

            # Remove the 'subgraph_id' field from the subgraph
            del subgraph['subgraph_id']

            # Add the current subgraph to the decomposed graph
            decomposed_graph[f'subgraph_{subgraph_id}'] = subgraph

          # Increment the subgraph ID
          subgraph_id += 1

    # Return the decomposed graph
    return dict(decomposed_graph)

