def decompose_graph(graph):
    """
    Decompose a given graph into a set of subgraphs where each subgraph contains strongly related nodes.
    
    Args:
    graph: A dictionary describing the graph, with 'nodes' and 'edges' keys containing lists of node IDs and edge descriptions.
    
    Returns:
    A dictionary with decomposed subgraphs, where each key is a subgraph name (int for now) and each value is a dictionary describing the subgraph, including 'nodes' and 'edges' lists.
    """

    # First, create an adjacency matrix to represent the graph as an undirected graph
    adjacency_matrix = {}
    for node, relations in graph['edges'].items():
        for relation in relations:
            if relation['target'] not in adjacency_matrix:
                adjacency_matrix[relation['target']] = {}
            adjacency_matrix[relation['target']][node] = relation

    # Initialize an empty list of discovered strongly connected components
    strongly_connected_components = []
    seen = set()
    # Initialize an empty subgraph dictionary
    subgraphs = {}

    # Depth-first search to find strongly connected components
    def dfs(node, subgraph_id):
        if node in seen:
            return
        seen.add(node)
        if node not in adjacency_matrix:
            return

        # Iterate through all adjacent nodes and recursively call dfs for each one
        for adjacent_node, relation in adjacency_matrix[node].items():
            # Add the node to the current subgraph
            current_subgraph = subgraphs.get(str(subgraph_id), {'nodes': [], 'edges': []})
            current_subgraph['nodes'].append({
                'id': node,
            })
            # Add the relation to the current subgraph
            current_subgraph['edges'].append({
                'source': node,
                'target': adjacent_node,
                'type': 'relation_type',
                'relation': relation
            })
            # Recursively call dfs for the adjacent node
            dfs(adjacent_node, subgraph_id)

    # Start dfs from each node in the graph
    for node in adjacency_matrix:
        # Create a new subgraph if necessary
        subgraph_id = len(strongly_connected_components) + 1
        if subgraph_id not in subgraphs:
            subgraphs[subgraph_id] = {'nodes': [], 'edges': []}
        # Call dfs for the current node
        dfs(node, subgraph_id)
        # Add the current subgraph to the list of strongly connected components
        strongly_connected_components.append(subgraph_id)

    # Finally, return the decomposed graph
    decomposed_graph = {}
    for subgraph_id, subgraph in subgraphs.items():
        decomposed_graph[f'subgraph_{subgraph_id}'] = subgraph

    return decomposed_graph


