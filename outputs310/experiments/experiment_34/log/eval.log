def decompose_strongly_connected_components(graph):
    stack = [node for node in graph.get('nodes', [])]

    strongly_connected_components = []
    subgraph_id = 0

    visited = set()

    while stack:
        node = stack.pop()

        if node['id'] not in visited:
            visited.add(node['id'])

            subgraph = {'nodes': [], 'edges': []}

            stack_nodes = [node]

            while stack_nodes:
                current_node = stack_nodes.pop()

                subgraph['nodes'].append({'id': current_node['id']})

                for edge in graph.get('edges', []):
                    if edge['source'] == current_node['id'] and edge['target'] not in stack_nodes:
                        subgraph['edges'].append(edge)
                        stack_nodes.append(graph['nodes'][edge['target']])

                stack_nodes.reverse()

            strongly_connected_components.append({
                f'subgraph_{subgraph_id}': subgraph
            })

            subgraph_id += 1

    return strongly_connected_components


