def decompose_graph(nodes, edges):
    """
    Decompose the given graph into subgraphs where each subgraph contains strongly related nodes.

    Args:
    nodes (dict): A dictionary of node IDs with properties (not used in this implementation)
    edges (dict): A dictionary of relation types with source and target node IDs
    Returns:
    dict: A dictionary of subgraphs, where each subgraph is represented as {'subgraph_1': {...}, 'subgraph_2': {...}, ...}
    """
    subgraphs = []
    node_groups = {}
    for node in nodes:
        # Initialize node as unvisited
        node_groups[node] = node

    for edge in edges:
        # Find the source node
        source_node = find_node(node_groups, edge['source'])
        # Find the target node
        target_node = find_node(node_groups, edge['target'])
        # If source and target nodes are in the same subgraph, add the edge
        if source_node == target_node:
            for subgraph in subgraphs:
                if source_node in subgraph['nodes']:
                    if target_node not in subgraph['nodes']:
                        subgraph['edges'].append({'source': edge['source'], 'target': edge['target'], 'type': edge['type']})
                    break
            else:
                # If not, a new subgraph is created
                new_subgraph = {
                    'nodes': [source_node, target_node],
                    'edges': [{'source': edge['source'], 'target': edge['target'], 'type': edge['type']}]
                }
                subgraphs.append(new_subgraph)
        
        # Update node groups
        group_source_node(source_node, target_node, node_groups)
        subgraphs = [update_subgraph_group(group_id, node_groups) for group_id, group in node_groups.items()]
    
    # Remove empty subgraphs
    subgraphs = [group for group in subgraphs if len(group['nodes']) > 0]
    return subgraphs

def group_id(group):
    return id(group) # or any other unique group identifier

def find_node(node_groups, node_id):
    for node, group in node_groups.items():
        if group_id(group) == node_id:
            return node

def group_source_node(node, target_node, node_groups):
    # Find nodes' groups and update the group IDs to be the same
    group_source_node_ = group_id(node_groups[node])
    group_target_node_ = group_id(node_groups[target_node])
    common_group = None
    for group_id, group in node_groups.items():
        if group_id == group_source_node_ or group_id == group_target_node_:
            if common_group is None:
                common_group = group_id
            elif common_group != group_id:
                raise ValueError("Nodes {} and {} are in different groups".format(node, target_node))
    for node, group in node_groups.items():
        if group_id(group) == common_group:
            group = common_group

def update_subgraph_group(group_id, node_groups):
    # Update subgraph with common node group
    for node, group in node_groups.items():
        if group_id(group) == group_id:
            # Update the 'nodes' list for the subgraph
            nodes = node_groups[node]['nodes']
            return {'id': group_id, 'nodes': nodes, 'edges': node_groups[node]['edges']}
    return {'id': group_id, 'nodes': [], 'edges': []}

